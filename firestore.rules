rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Règle pour les profils utilisateurs
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth.uid == userId;
    }

    // Règle pour les générations de vidéos
    match /videoGenerations/{generationId} {
      // Tout utilisateur authentifié peut créer un document de génération.
      allow create: if request.auth != null;
      
      // Seul l'utilisateur qui a créé la génération (dont l'ID est dans `userId`)
      // est autorisé à lire le document complet (y compris le champ `videoUrl`)
      // ou à le mettre à jour.
      allow read, update: if request.auth.uid == resource.data.userId;
    }
  }
}
